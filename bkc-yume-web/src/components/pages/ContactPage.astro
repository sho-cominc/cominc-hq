---
import type { Locale } from '~/utils/i18n';
import { t, SOCIAL } from '~/utils/i18n';
import Base from '~/layouts/Base.astro';
import SectionHeading from '~/components/SectionHeading.astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const dict = t(locale);
---

<Base locale={locale} title={dict.meta.contact.title} description={dict.meta.contact.description}>
  <section class="mx-auto max-w-3xl px-5 pt-16 md:pt-24">
    <SectionHeading eyebrow="CONTACT" title={dict.contact.title} lede={dict.contact.lede} />
  </section>

  <section class="mx-auto max-w-3xl px-5 py-12 space-y-4">
    <a
      href={SOCIAL.instagramDm}
      target="_blank"
      rel="noopener noreferrer"
      class="group block rounded-blob bg-berry p-6 text-ink transition hover:brightness-110"
    >
      <p class="text-[11px] uppercase tracking-[0.25em] opacity-70">Instagram DM</p>
      <p class="mt-1 font-display text-2xl md:text-3xl">{dict.contact.dmButton} →</p>
      <p class="mt-2 text-sm opacity-80">@{SOCIAL.instagramHandle}</p>
    </a>

    <a
      href={`mailto:${SOCIAL.email}`}
      class="group block rounded-blob border border-cream/20 p-6 text-cream transition hover:bg-cream/5"
    >
      <p class="text-[11px] uppercase tracking-[0.25em] text-cream/60">Email</p>
      <p class="mt-1 font-display text-2xl">{dict.contact.emailButton} →</p>
      <p class="mt-2 text-sm text-cream/60">{SOCIAL.email}</p>
    </a>

    <a
      href={SOCIAL.threadsUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="group block rounded-blob border border-cream/20 p-6 text-cream transition hover:bg-cream/5"
    >
      <p class="text-[11px] uppercase tracking-[0.25em] text-cream/60">Threads</p>
      <p class="mt-1 font-display text-2xl">{dict.contact.threadsButton} →</p>
    </a>

    <p class="pt-4 text-sm text-cream/60">{dict.contact.responseNote}</p>
  </section>

  <section class="mx-auto max-w-3xl px-5 pb-24">
    <div class="rounded-blob border border-line bg-ink/60 p-6 md:p-8">
      <h2 class="font-display text-2xl text-cream">{dict.contact.eventRequestHeading}</h2>
      <p class="mt-3 text-cream/70 leading-relaxed">{dict.contact.eventRequestBody}</p>
    </div>
  </section>
</Base>
