---
import type { Locale } from '~/utils/i18n';
import { t } from '~/utils/i18n';
import { faqPageSchema } from '~/utils/schema';
import Base from '~/layouts/Base.astro';
import SectionHeading from '~/components/SectionHeading.astro';
import JsonLd from '~/components/JsonLd.astro';
import faq from '~/data/faq.json';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const dict = t(locale);
---

<Base locale={locale} title={dict.meta.faq.title} description={dict.meta.faq.description}>
  <section class="mx-auto max-w-3xl px-5 pt-16 md:pt-24">
    <SectionHeading eyebrow="FAQ" title={dict.faq.title} lede={dict.faq.lede} />
  </section>

  <section class="mx-auto max-w-3xl px-5 pb-24 pt-10 space-y-3">
    {faq.map((item) => (
      <details class="group rounded-blob border border-line bg-ink/60 p-5 open:bg-ink/80 transition-colors">
        <summary class="flex cursor-pointer list-none items-start justify-between gap-4 text-cream">
          <span class="font-display text-lg leading-tight">
            {locale === 'ja' ? item.q_ja : item.q_en}
          </span>
          <span class="mt-1 shrink-0 text-cream/60 transition-transform group-open:rotate-45">+</span>
        </summary>
        <p class="mt-3 text-cream/75 leading-relaxed whitespace-pre-line">
          {locale === 'ja' ? item.a_ja : item.a_en}
        </p>
      </details>
    ))}
  </section>

  <JsonLd data={faqPageSchema(locale, faq)} />
</Base>
